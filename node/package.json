{
  "name": "rbmq",
  "version": "1.0.0-alpha.1",
  "description": "Redis Better Message Queue. A small, atomic Redis-backed queue. All semantics live in Lua scripts shared with the Rust implementation.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "scripts",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:interop": "vitest run test/interop.test.js"
  },
  "keywords": [
    "redis",
    "queue",
    "message-queue",
    "lua",
    "ioredis"
  ],
  "author": "David Bonet <webbonet@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/DavidBM/rsmq-async-rs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DavidBM/rsmq-async-rs.git"
  },
  "dependencies": {
    "ioredis": "5.10.1"
  },
  "devDependencies": {
    "vitest": "4.1.5"
  }
}
